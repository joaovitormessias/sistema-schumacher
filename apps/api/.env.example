# API environment variables
APP_ENV=production
PORT=8080
CORS_ORIGINS=
DATABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWKS_URL=
SUPABASE_ISSUER=
SUPABASE_AUDIENCE=authenticated
AUTH_DISABLED=false
# Used only when AUTH_DISABLED=true (local debug). Must be a valid UUID.
AUTH_DEBUG_USER_ID=00000000-0000-0000-0000-000000000001
API_SERVICE_TOKENS=
ABACATEPAY_API_KEY=
ABACATEPAY_WEBHOOK_SECRET=
ABACATEPAY_BASE_URL=https://api.abacatepay.com/v1
ABACATEPAY_PUBLIC_KEY=
# TODO(abacatepay-domain): Use hosted frontend URL, e.g. https://app.example.com/pagamento/retorno
ABACATEPAY_RETURN_URL=
# TODO(abacatepay-domain): Use hosted frontend URL, e.g. https://app.example.com/pagamento/concluido
ABACATEPAY_COMPLETION_URL=
# TODO(abacatepay-domain): In AbacatePay panel, webhook URL must use public API domain:
# https://api.example.com/webhooks/abacatepay
PAGARME_SECRET_KEY=
PAGARME_BASE_URL=https://api.pagar.me/core/v5
PAGARME_API_BASE_URL=https://api.pagar.me/core/v5
# Optional for AUTH_DISABLED=true: use a fixed recipient to fetch real balance in bypass mode.
PAGARME_DEBUG_RECIPIENT_ID=
PAGARME_WEBHOOK_BASIC_USER=
PAGARME_WEBHOOK_BASIC_PASS=
CHAT_REVIEW_ALERT_WEBHOOK_URL=

# Chat / automation foundation
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_VISION_MODEL=
OPENAI_TRANSCRIPTION_MODEL=
EVOLUTION_BASE_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=
EVOLUTION_WEBHOOK_SECRET=
CHAT_DEBOUNCE_WINDOW_MS=1500
CHAT_BUFFER_AUTO_FLUSH_ENABLED=false
CHAT_BUFFER_AUTO_FLUSH_INTERVAL_SECONDS=2
CHAT_BUFFER_AUTO_FLUSH_LIMIT=100
CHAT_AUTO_SEND_RETRY_ENABLED=false
CHAT_AUTO_SEND_RETRY_INTERVAL_SECONDS=10
CHAT_AUTO_SEND_RETRY_LIMIT=20
CHAT_AUTO_SEND_RETRY_COOLDOWN_SECONDS=30
CHAT_REVIEW_SLA_MINUTES=15
CHAT_DEFAULT_HANDOFF_MODE=BOT
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=
